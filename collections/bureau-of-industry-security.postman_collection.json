          "name": "Search the Consolidated Screening List",
          "request": {
            "name": "Search the Consolidated Screening List",
            "description": {
              "content": "Search across all entries on the Consolidated Screening List.\nReturns matching parties with name, addresses, country, source\nlist, and remarks. Supports fuzzy name matching.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "search"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "name",
                  "value": "<string>",
                  "description": "Name of an individual or entity to search for."
                },
                {
                  "disabled": false,
                  "key": "fuzzy_name",
                  "value": "false",
                  "description": "When true, applies fuzzy name matching."
                },
                {
                  "disabled": false,
                  "key": "sources",
                  "value": "<string>",
                  "description": "Comma-separated list of source list codes (e.g., SDN, EL, DPL)."
                },
                {
                  "disabled": false,
                  "key": "types",
                  "value": "<string>",
                  "description": "Comma-separated list of party types (Individual, Entity, Vessel, Aircraft)."
                },
                {
                  "disabled": false,
                  "key": "countries",
                  "value": "<string>",
                  "description": "Comma-separated list of ISO 3166-1 alpha-2 country codes."
                },
                {
                  "disabled": false,
                  "key": "address",
                  "value": "<string>",
                  "description": "Street address fragment to search."
                },
                {
                  "disabled": false,
                  "key": "city",
                  "value": "<string>"
                },
                {
                  "disabled": false,
                  "key": "state",
                  "value": "<string>"
                },
                {
                  "disabled": false,
                  "key": "postal_code",
                  "value": "<string>"
                },
                {
                  "disabled": false,
                  "key": "size",
                  "value": "10",
                  "description": "Number of results to return (max 100)."
                },
                {
                  "disabled": false,
                  "key": "offset",
                  "value": "0",
                  "description": "Result offset for pagination."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
